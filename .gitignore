.claude
# Generated by Cargo
# will have compiled files and executables
debug/
target/
.idea
jacs/documents/*
# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb
.cursor
.vscode
grant.md
scratch.md
jacs.config.json
!jacs/jacs.config.json
.DS_Store

# Runtime artifacts from tests
var/
documents/
jacsnpm/var/

# Generated by quickstart/persistent agent tests
**/jacs_data/
**/jacs_keys/

# Local dev overrides — do not commit
.cargo/config.toml

# wasm-pack output — regenerated by `wasm-pack build` and `make build-wasm`.
jacs-wasm/pkg/
